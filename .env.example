# AISStream API key - get one at https://aisstream.io
AISSTREAM_API_KEY=your_aisstream_api_key_here

# MongoDB connection string (MongoDB Atlas or local)
# Atlas format: mongodb+srv://user:password@cluster.mongodb.net/?appName=ClusterName
# Local format: mongodb://localhost:27017
MONGODB_URI=mongodb://localhost:27017

# Port (Render sets this automatically, only needed locally)
PORT=3000
